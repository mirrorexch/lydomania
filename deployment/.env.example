# =====================================================================
# Lydomania — production env file.  COPY this to `.env` and fill in.
# Never commit `.env`. Never paste your real values into chat/screenshots.
#
# Run `./scripts/rotate-secrets.sh` to auto-generate the *_SECRET / *_KEY
# / MONGO_INITDB_ROOT_PASSWORD lines.
# Run `./scripts/generate-ton-vault.sh` to mint a brand-new TON vault.
# =====================================================================

# ----- DOMAIN + HTTPS (you set these) -----
DOMAIN=lydomania.example.com           # the exact host you'll point at this VPS
ACME_EMAIL=you@example.com             # Let's Encrypt account email (recoveries)
MINI_APP_URL=https://lydomania.example.com   # MUST match https://DOMAIN

# ----- Telegram (you set these) -----
TELEGRAM_BOT_TOKEN=                    # from @BotFather
TELEGRAM_BOT_USERNAME=lydomania777_bot # without leading @
ADMIN_TELEGRAM_IDS=                    # comma-separated TG IDs (DM @userinfobot to find yours)

# ----- TON vault (generate via scripts/generate-ton-vault.sh) -----
TON_NETWORK=mainnet
TON_VAULT_MNEMONIC=                    # 24-word seed — NEVER share, NEVER paste online
TONCENTER_API_BASE=https://toncenter.com/api/v2
TONCENTER_API_KEY=                     # free key at https://toncenter.com (recommended)

# ----- Secrets (rotated by scripts/rotate-secrets.sh) -----
JWT_SECRET=
INTERNAL_API_SECRET=
SETTINGS_ENCRYPTION_KEY=
ADMIN_API_KEY=

# ----- Mongo credentials (rotated by scripts/rotate-secrets.sh) -----
MONGO_INITDB_ROOT_USERNAME=lydomania
MONGO_INITDB_ROOT_PASSWORD=
DB_NAME=lydomania

# ----- Safety toggles -----
ENABLE_DEV_LOGIN=false                 # ABSOLUTELY MUST be false in production

# ----- Game tuning (sensible defaults — change later via /admin/settings UI) -----
REFERRAL_PCT=0.05
